<?xml version="1.0" encoding="UTF-8"?>
<definition:ConnectorDefinition
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:definition="http://www.bonitasoft.org/ns/connector/definition/6.1">

  <id>${adobesign-create-agreement.def.id}</id>
  <version>${adobesign-create-agreement.def.version}</version>
  <icon>adobesign.png</icon>
  <category icon="adobesign.png" id="Adobe Sign"/>

  <!-- Connection inputs -->
  <input name="authMode" type="java.lang.String" mandatory="true" defaultValue="INTEGRATION_KEY"/>
  <input name="integrationKey" type="java.lang.String" mandatory="false"/>
  <input name="clientId" type="java.lang.String" mandatory="false"/>
  <input name="clientSecret" type="java.lang.String" mandatory="false"/>
  <input name="refreshToken" type="java.lang.String" mandatory="false"/>
  <input name="region" type="java.lang.String" mandatory="false" defaultValue="na1"/>
  <input name="baseUrl" type="java.lang.String" mandatory="false"/>
  <input name="connectTimeout" type="java.lang.Integer" mandatory="false" defaultValue="30000"/>
  <input name="readTimeout" type="java.lang.Integer" mandatory="false" defaultValue="60000"/>

  <!-- Operation inputs -->
  <input name="documentBase64" type="java.lang.String" mandatory="true"/>
  <input name="documentName" type="java.lang.String" mandatory="true"/>
  <input name="agreementName" type="java.lang.String" mandatory="true"/>
  <input name="signerEmail" type="java.lang.String" mandatory="true"/>
  <input name="additionalParticipantSets" type="java.lang.String" mandatory="false"/>
  <input name="ccEmails" type="java.lang.String" mandatory="false"/>
  <input name="emailSubject" type="java.lang.String" mandatory="false"/>
  <input name="message" type="java.lang.String" mandatory="false"/>
  <input name="signatureType" type="java.lang.String" mandatory="false" defaultValue="ESIGN"/>
  <input name="expirationDays" type="java.lang.Integer" mandatory="false"/>
  <input name="reminderFrequency" type="java.lang.String" mandatory="false"/>
  <input name="locale" type="java.lang.String" mandatory="false" defaultValue="en_US"/>
  <input name="signatureFlow" type="java.lang.String" mandatory="false" defaultValue="SENDER_SIGNS_LAST"/>

  <!-- Outputs -->
  <output name="agreementId" type="java.lang.String"/>
  <output name="agreementStatus" type="java.lang.String"/>
  <output name="transientDocumentId" type="java.lang.String"/>
  <output name="success" type="java.lang.Boolean"/>
  <output name="errorMessage" type="java.lang.String"/>

  <!-- UI Pages -->
  <page id="connectionPage">
    <widget xsi:type="definition:Select" id="authModeWidget" inputName="authMode">
      <items>INTEGRATION_KEY</items>
      <items>OAUTH2</items>
    </widget>
    <widget xsi:type="definition:Password" id="integrationKeyWidget" inputName="integrationKey"/>
    <widget xsi:type="definition:Text" id="clientIdWidget" inputName="clientId"/>
    <widget xsi:type="definition:Password" id="clientSecretWidget" inputName="clientSecret"/>
    <widget xsi:type="definition:Password" id="refreshTokenWidget" inputName="refreshToken"/>
    <widget xsi:type="definition:Select" id="regionWidget" inputName="region">
      <items>na1</items>
      <items>na2</items>
      <items>eu1</items>
      <items>eu2</items>
      <items>jp1</items>
      <items>au1</items>
    </widget>
    <widget xsi:type="definition:Text" id="baseUrlWidget" inputName="baseUrl"/>
    <widget xsi:type="definition:Text" id="connectTimeoutWidget" inputName="connectTimeout"/>
    <widget xsi:type="definition:Text" id="readTimeoutWidget" inputName="readTimeout"/>
  </page>
  <page id="operationPage">
    <widget xsi:type="definition:Text" id="documentBase64Widget" inputName="documentBase64"/>
    <widget xsi:type="definition:Text" id="documentNameWidget" inputName="documentName"/>
    <widget xsi:type="definition:Text" id="agreementNameWidget" inputName="agreementName"/>
    <widget xsi:type="definition:Text" id="signerEmailWidget" inputName="signerEmail"/>
    <widget xsi:type="definition:TextArea" id="additionalParticipantSetsWidget" inputName="additionalParticipantSets"/>
    <widget xsi:type="definition:TextArea" id="ccEmailsWidget" inputName="ccEmails"/>
    <widget xsi:type="definition:Text" id="emailSubjectWidget" inputName="emailSubject"/>
    <widget xsi:type="definition:TextArea" id="messageWidget" inputName="message"/>
    <widget xsi:type="definition:Select" id="signatureTypeWidget" inputName="signatureType">
      <items>ESIGN</items>
      <items>WRITTEN</items>
    </widget>
    <widget xsi:type="definition:Text" id="expirationDaysWidget" inputName="expirationDays"/>
    <widget xsi:type="definition:Select" id="reminderFrequencyWidget" inputName="reminderFrequency">
      <items>DAILY_UNTIL_SIGNED</items>
      <items>WEEKLY_UNTIL_SIGNED</items>
      <items>EVERY_OTHER_DAY_UNTIL_SIGNED</items>
      <items>EVERY_THIRD_DAY_UNTIL_SIGNED</items>
      <items>EVERY_FIFTH_DAY_UNTIL_SIGNED</items>
    </widget>
    <widget xsi:type="definition:Text" id="localeWidget" inputName="locale"/>
    <widget xsi:type="definition:Select" id="signatureFlowWidget" inputName="signatureFlow">
      <items>SENDER_SIGNATURE_NOT_REQUIRED</items>
      <items>SENDER_SIGNS_LAST</items>
      <items>SENDER_SIGNS_FIRST</items>
      <items>SEQUENTIAL</items>
      <items>PARALLEL</items>
    </widget>
  </page>
</definition:ConnectorDefinition>
